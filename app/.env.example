# Server-side secrets — NEVER expose these to the browser
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
API_BASE_URL=https://your-backend-api.com
API_SECRET_KEY=your_secret_key_here

# Odoo
ODOO_BASE_URL=https://your-odoo-instance.odoo.com
ODOO_API_KEY=your_odoo_api_key_here
ODOO_SESSION_ID=your_odoo_session_id_here

# Public runtime config
NUXT_PUBLIC_APP_NAME=RubikX Builder

# Nitro preset — leave as node-server for local dev
# Amplify sets NITRO_PRESET=aws-amplify automatically via amplify.yml
NITRO_PRESET=node-server
