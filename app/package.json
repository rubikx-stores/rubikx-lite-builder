{
  "name": "rubikx-web",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||'';if(!ua.startsWith('pnpm')){console.error('\\n\\u274C Use pnpm, not npm/yarn. Run: pnpm install\\n');process.exit(1)}\"",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "nuxt typecheck",
    "format": "prettier --write .",
    "clean": "rimraf .nuxt .output dist node_modules"
  },
  "dependencies": {
    "@myissue/vue-website-page-builder": "file:../",
    "nuxt": "^3.16.0",
    "vue": "^3.5.13",
    "h3": "^1.15.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "vue-demi"
    ]
  }
}